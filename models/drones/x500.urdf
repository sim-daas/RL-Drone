<?xml version="1.0" ?>
<robot name="drone">

  <material name="white"><color rgba="0.65 0.65 0.65 1.0"/></material>
  <material name="green"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="rotor_red"><color rgba="0.8 0.1 0.1 1.0"/></material>
  <material name="body_color"><color rgba="0.1 0.1 0.1 1.0"/></material>

  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="Dronebase.stl" scale="1 1 1"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.02166666666666667" ixy="0" ixz="0" iyy="0.02166666666666667" iyz="0" izz="0.04000000000000001"/>
    </inertial>
  </link>

  <link name="front_right_prop">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/><geometry><cylinder length="0.01" radius="0.02"/></geometry><material name="green"/></visual>
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <joint name="base_to_front_right_prop" type="fixed">
    <parent link="base_link"/><child link="front_right_prop"/><origin xyz="0.16 -0.16 0"/><axis xyz="1 0 0"/>
  </joint>

  <link name="back_left_prop">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/><geometry><cylinder length="0.01" radius="0.02"/></geometry><material name="green"/></visual>
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <joint name="base_to_back_left_prop" type="fixed">
    <parent link="base_link"/><child link="back_left_prop"/><origin xyz="-0.16 0.16 0"/><axis xyz="1 0 0"/>
  </joint>

  <link name="front_left_prop">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/><geometry><cylinder length="0.01" radius="0.02"/></geometry><material name="green"/></visual>
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <joint name="base_to_front_left_prop" type="fixed">
    <parent link="base_link"/><child link="front_left_prop"/><origin xyz="0.16 0.16 0"/><axis xyz="1 0 0"/>
  </joint>

  <link name="back_right_prop">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/><geometry><cylinder length="0.01" radius="0.02"/></geometry><material name="green"/></visual>
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <joint name="base_to_back_right_prop" type="fixed">
    <parent link="base_link"/><child link="back_right_prop"/><origin xyz="-0.16 -0.16 0"/><axis xyz="1 0 0"/>
  </joint>

  <link name="body">
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
  </link>
  <joint name="body_link" type="fixed">
    <parent link="base_link"/><child link="body"/><origin xyz="0 0 0"/><axis xyz="0 0 0"/>
  </joint>

  <link name="visual_rotor1">
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
    <visual><origin xyz="0.06 0 0.001" rpy="0 0 0"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 0.052 0.001" rpy="0 0 2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 -0.052 0.001" rpy="0 0 -2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="0.09 0 0.002" rpy="0 0 0"/><geometry><box size="0.04 0.035 0.003"/></geometry><material name="green"/></visual>
    <visual><origin xyz="0 0 0.001" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.006"/></geometry><material name="body_color"/></visual>
  </link>
  <joint name="visual_rotor1_joint" type="continuous">
    <parent link="base_link"/><child link="visual_rotor1"/><origin xyz="0.16 -0.16 0.015" rpy="0 0 0"/><axis xyz="0 0 1"/><dynamics damping="0.0" friction="0.0"/>
  </joint>

 <link name="visual_rotor2">
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
    <visual><origin xyz="0.06 0 0.001" rpy="0 0 0"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 0.052 0.001" rpy="0 0 2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 -0.052 0.001" rpy="0 0 -2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="0.09 0 0.002" rpy="0 0 0"/><geometry><box size="0.04 0.035 0.003"/></geometry><material name="green"/></visual>
    <visual><origin xyz="0 0 0.001" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.006"/></geometry><material name="body_color"/></visual>
  </link>
  <joint name="visual_rotor2_joint" type="continuous">
    <parent link="base_link"/><child link="visual_rotor2"/><origin xyz="-0.16 0.16 0.015" rpy="0 0 0"/><axis xyz="0 0 1"/><dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="visual_rotor3">
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
    <visual><origin xyz="0.06 0 0.001" rpy="0 0 0"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 0.052 0.001" rpy="0 0 2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 -0.052 0.001" rpy="0 0 -2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="0.09 0 0.002" rpy="0 0 0"/><geometry><box size="0.04 0.035 0.003"/></geometry><material name="green"/></visual>
    <visual><origin xyz="0 0 0.001" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.006"/></geometry><material name="body_color"/></visual>
  </link>
  <joint name="visual_rotor3_joint" type="continuous">
    <parent link="base_link"/><child link="visual_rotor3"/><origin xyz="0.16 0.16 0.015" rpy="0 0 0"/><axis xyz="0 0 1"/><dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="visual_rotor4">
    <inertial><mass value="0"/><inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/></inertial>
    <visual><origin xyz="0.06 0 0.001" rpy="0 0 0"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 0.052 0.001" rpy="0 0 2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="-0.03 -0.052 0.001" rpy="0 0 -2.0944"/><geometry><box size="0.12 0.03 0.002"/></geometry><material name="rotor_red"/></visual>
    <visual><origin xyz="0.09 0 0.002" rpy="0 0 0"/><geometry><box size="0.04 0.035 0.003"/></geometry><material name="green"/></visual>
    <visual><origin xyz="0 0 0.001" rpy="0 0 0"/><geometry><cylinder radius="0.02" length="0.006"/></geometry><material name="body_color"/></visual>
  </link>
  <joint name="visual_rotor4_joint" type="continuous">
    <parent link="base_link"/><child link="visual_rotor4"/><origin xyz="-0.16 -0.16 0.015" rpy="0 0 0"/><axis xyz="0 0 1"/><dynamics damping="0.0" friction="0.0"/>
  </joint>
</robot>